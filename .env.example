OPENROUTER_API_KEY=replace_with_your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=xiaomi/mimo-v2-pro
# Optional but recommended for OpenRouter ranking and attribution.
# OPENROUTER_HTTP_REFERER=https://your-domain.example.com
# OPENROUTER_APP_NAME=Fitness Food

# Optional fallback if you want to switch back to a DashScope-compatible primary model.
# DASHSCOPE_API_KEY=replace_with_your_dashscope_api_key
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# PRIMARY_MODEL_ID=replace_with_your_dashscope_model_id
PRIMARY_MODEL_ENABLE_THINKING=true
PRIMARY_MODEL_ENABLE_SEARCH=true
# Optional: force every request to search the web.
# PRIMARY_MODEL_FORCE_SEARCH=false
# Optional: `turbo` is faster; `max` is deeper but slower.
# PRIMARY_MODEL_SEARCH_STRATEGY=turbo
# Optional override for search/thinking heavy requests.
# PRIMARY_MODEL_REQUEST_TIMEOUT_MS=45000
# Optional: lighter settings for the secondary reviewer only.
# PRIMARY_MODEL_REVIEW_ENABLE_THINKING=false
# PRIMARY_MODEL_REVIEW_ENABLE_SEARCH=false
# PRIMARY_MODEL_REVIEW_REQUEST_TIMEOUT_MS=15000
# PRIMARY_MODEL_REVIEW_MAX_ATTEMPTS=1
# PRIMARY_MODEL_REVIEW_MAX_TOKENS=1024
# Optional: extra consensus reviewers. Official MiniMax OpenAI-compatible API.
# SECONDARY_REVIEW_ENABLE_MINIMAX=true
# MINIMAX_API_KEY=replace_with_your_minimax_api_key
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_REVIEW_MODEL=MiniMax-M2.7
# MINIMAX_REVIEW_TIMEOUT_MS=25000
# SECONDARY_REVIEW_TIMEOUT_MS is legacy for older wrappers and does not cap the current reviewer chain.
# SECONDARY_REVIEW_ENABLE_DEEPSEEK=false

# Optional: official DeepSeek reviewer. `deepseek-chat` maps to DeepSeek-V3.2 in non-thinking mode.
# DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_REQUEST_TIMEOUT_MS=45000

# Optional: parallel AI estimation model/timeout overrides (used by 3AI cross-validation).
# If not set, these default to the review model for each provider.
# MINIMAX_PARSE_MODEL=MiniMax-M2.7
# MINIMAX_PARSE_TIMEOUT_MS=25000
# DEEPSEEK_PARSE_MODEL=deepseek-chat
# DEEPSEEK_PARSE_TIMEOUT_MS=25000

# Required for magic-link auth links in production.
APP_BASE_URL=https://your-domain.example.com

# SMTP is optional until you enable email login.
SMTP_HOST=smtp.your-provider.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=Fitness Food <noreply@your-domain.example.com>

# Recommended for local development when your PostgreSQL instance is on the same machine.
DATABASE_URL=postgresql://localhost:5432/foodetl_local

# If you prefer discrete PG* vars instead of DATABASE_URL, delete DATABASE_URL above
# and configure these instead.
# PGDATABASE=foodetl_local
# PGHOST=localhost
# PGPORT=5432
# PGUSER=your_pg_user
# PGPASSWORD=your_pg_password

# Optional: on Debian servers where materialized views are owned by postgres,
# set this so the refresh timer uses `sudo -u postgres psql -d <db>`.
# PG_REFRESH_AS_POSTGRES=1
